# SQLite file path. In production this should point at a Railway volume mount,
# e.g. /data/jisoku.db. Locally, ./data/jisoku.db is the default.
DATABASE_PATH=./data/jisoku.db

# 32+ random bytes for HMAC of admin cookie. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Admin password — what admins type at /admin/auth.
# Pick something long and random; treat it like any other secret.
ADMIN_SECRET=

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Public site URL (used in recovery URLs shown to users)
NEXT_PUBLIC_SITE_URL=https://jisoku.sukoshi.net
